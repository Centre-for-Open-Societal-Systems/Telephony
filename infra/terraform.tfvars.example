# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

# AWS region to deploy the PBX
aws_region    = "ap-northeast-1"
instance_type = "t3.small"

# AMI credentials (lead-service will use these to connect to the PBX)
ami_username = "lead-ami"
ami_password = "CHANGE_ME_TO_A_STRONG_PASSWORD"

# Your SIP provider configuration
# Example for Twilio: "your-domain.pstn.twilio.com"
# For other providers, use their SIP domain
sip_provider_domain = "your-domain.pstn.twilio.com"

# Your inbound phone number (DID)
inbound_did = "+1XXXXXXXXXX"

# Dialplan context — must match telephony.lead-context-allowlist in lead-service
dialplan_context = "from-missed-call"

# SIP provider IP ranges — defaults are Twilio's ranges.
# If using a different provider, replace with their published IP ranges.
# sip_signalling_cidrs = ["x.x.x.x/xx", "y.y.y.y/yy"]
# sip_media_cidrs      = ["x.x.x.x/xx", "y.y.y.y/yy"]
