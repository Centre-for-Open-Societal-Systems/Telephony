# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=lead_db
POSTGRES_USER=lead_user
POSTGRES_PASSWORD=lead_password

# ── AMI Connection (Asterisk PBX) ───────────────────────────────────────────
# Set to true when you have a live PBX to connect to
AMI_ENABLED=false
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=lead-ami
AMI_SECRET=changeme

# ── Lead Filtering ──────────────────────────────────────────────────────────
LEAD_CONTEXT=from-missed-call

# ── Lead Dispatch (optional) ────────────────────────────────────────────────
# URL to POST leads to. Leave empty to only log to database.
LEAD_REGISTRY_URL=
LEAD_REGISTRY_API_KEY_HEADER=
LEAD_REGISTRY_API_KEY_VALUE=

# ── pgAdmin ────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

